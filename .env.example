# Zoho Mail SMTP — used by /api/contact on Vercel
# Create an app-specific password: Zoho Mail → Settings → Security → App Passwords
# IMPORTANT: Also add these same variables in Vercel → Project → Settings → Environment Variables, then redeploy.
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ZOHO_SMTP_HOST=
ZOHO_SMTP_PORT=

# Inbox that receives contact form submissions (e.g. tinkler@nifafarms.com)
CONTACT_TO_EMAIL=

# Local dev: "npm run dev" loads this file and serves /api/contact on port 5173
