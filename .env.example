# EmailJS — contact form (https://www.emailjs.com/)
# Create a Zoho service, email template, and copy IDs from the EmailJS dashboard.
# Template variables: {{name}}, {{company}}, {{email}}, {{subject}}, {{message}}, {{reply_to}}
# Also add these in Vercel → Project → Settings → Environment Variables (VITE_ prefix required), then redeploy.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
